# Skill API keys can now be configured in the UI at Settings → Environment Variables.
# .env values are still supported as fallback.
BRAVE_API_KEY=your-brave-api-key-here

# Override the data directory used by the backend (auth, sessions, agents, uploads).
# Defaults to ~/.nexus if not set. Dev scripts set this to ~/.nexus-dev automatically.
# NEXUS_DATA_DIR=~/.nexus-dev

# NEXUS_HOST=0.0.0.0